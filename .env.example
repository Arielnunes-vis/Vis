# =====================================================
# VIS — Variáveis de ambiente (EXEMPLO)
# -----------------------------------------------------
# Copie este arquivo para ".env" e preencha com os
# valores reais. O arquivo ".env" NUNCA deve ser
# versionado (já está no .gitignore).
#
# As variáveis são carregadas em runtime pelo pacote
# flutter_dotenv. Nenhuma chave real deve ficar
# hardcoded no código (10_DEVELOPMENT_RULES.md — Regra 12).
# =====================================================

# ----- Supabase -----
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ----- OpenAI (consumida via Supabase Edge Functions) -----
OPENAI_API_URL=
OPENAI_MODEL=
